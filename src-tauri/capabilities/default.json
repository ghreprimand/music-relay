{
  "$schema": "https://raw.githubusercontent.com/nicedaycode/tauri-schema/v2/capabilities-schema.json",
  "identifier": "default",
  "description": "Default permissions for Music Relay",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-open",
      "allow": [
        { "url": "https://developer.spotify.com/*" }
      ]
    },
    "store:default",
    "autostart:default",
    {
      "identifier": "core:window:allow-show",
      "windows": ["main"]
    },
    {
      "identifier": "core:window:allow-hide",
      "windows": ["main"]
    },
    {
      "identifier": "core:window:allow-close",
      "windows": ["main"]
    },
    {
      "identifier": "core:window:allow-set-focus",
      "windows": ["main"]
    }
  ]
}
